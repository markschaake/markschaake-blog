---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title" aria-label={SITE_TITLE}>
			<span class="prompt" aria-hidden="true">~</span><span class="wordmark">mark-schaake</span><span class="cursor" aria-hidden="true"></span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/posts">Posts</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/in/mark-schaake/" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Connect with Mark on LinkedIn</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
					<path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
			</a>
			<a href="https://x.com/markschaake" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Follow Mark on X</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
					<path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
				</svg>
			</a>
			<a href="https://github.com/markschaake" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Mark's GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
			<a href="/rss.xml">
				<span class="sr-only">Subscribe via RSS</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
					<path fill="currentColor" d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		background: color-mix(in srgb, var(--color-gray-50) 90%, transparent);
		backdrop-filter: saturate(180%) blur(10px);
		-webkit-backdrop-filter: saturate(180%) blur(10px);
		border-bottom: 1px solid var(--color-gray-200);
		position: sticky;
		top: 0;
		z-index: 50;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 72rem;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		gap: 2rem;
	}

	.site-title {
		font-family: var(--font-mono);
		font-size: 1.0625rem;
		font-weight: 500;
		color: var(--color-gray-900);
		text-decoration: none;
		letter-spacing: -0.01em;
		display: inline-flex;
		align-items: baseline;
		white-space: nowrap;
	}

	.site-title:hover {
		color: var(--color-gray-900);
		text-decoration: none;
	}

	.site-title:hover .wordmark {
		color: var(--color-accent);
	}

	.prompt {
		color: var(--color-terminal);
		margin-right: 0.5ch;
		font-weight: 600;
	}

	.wordmark {
		transition: color 0.15s ease;
	}

	.cursor {
		display: inline-block;
		width: 0.55ch;
		height: 1.05em;
		background-color: var(--color-terminal);
		margin-left: 0.3ch;
		transform: translateY(0.15em);
		animation: cursor-blink 1.06s steps(1) infinite;
	}

	@keyframes cursor-blink {
		0%, 50% { opacity: 1; }
		50.01%, 100% { opacity: 0; }
	}

	@media (prefers-reduced-motion: reduce) {
		.cursor {
			animation: none;
			opacity: 1;
		}
	}

	.nav-links {
		display: flex;
		gap: 1.5rem;
		margin-left: auto;
	}

	.social-links {
		display: flex;
		gap: 0.75rem;
	}

	.social-links a {
		color: var(--color-gray-500);
		transition: color 0.15s ease;
		display: inline-flex;
		align-items: center;
	}

	.social-links a:hover {
		color: var(--color-gray-900);
	}

	@media (max-width: 640px) {
		nav {
			padding: 0.75rem 1rem;
			gap: 1rem;
		}

		.nav-links {
			gap: 1rem;
		}

		.social-links {
			display: none;
		}

		.site-title {
			font-size: 1rem;
		}
	}

	@media (prefers-color-scheme: dark) {
		header {
			background: color-mix(in srgb, var(--color-gray-900) 85%, transparent);
			border-bottom-color: var(--color-gray-700);
		}

		.site-title {
			color: var(--color-gray-50);
		}

		.site-title:hover {
			color: var(--color-gray-50);
		}

		.site-title:hover .wordmark {
			color: #60a5fa;
		}

		.social-links a {
			color: var(--color-gray-400);
		}

		.social-links a:hover {
			color: var(--color-gray-50);
		}
	}
</style>
