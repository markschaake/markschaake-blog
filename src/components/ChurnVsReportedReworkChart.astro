---
---

<div class="chart-container">
  <div class="chart-header">
    <div class="chart-title">Two Rework Signals, One Timeline</div>
    <div class="chart-subtitle">File-level churn vs. commit-reported rework, 7-day trailing averages</div>
  </div>
  <canvas id="churn-vs-reported-chart"></canvas>
</div>

<script>
  import { Chart, registerables } from 'chart.js';
  Chart.register(...registerables);

  // Illustrative data: ~8 weeks of expected patterns once trailer data accumulates
  // Weeks 1-2: trailer coverage ramps up (not all commits have trailers yet)
  // Weeks 3-5: both signals running, generally tracking but with divergences
  // Weeks 6-8: higher coverage, divergences become informative
  const labels = [
    'W1', '', '', '', 'W2', '', '', '',
    'W3', '', '', '', 'W4', '', '', '',
    'W5', '', '', '', 'W6', '', '', '',
    'W7', '', '', '', 'W8', '', '', '',
  ];

  // Machine:wall ratio - continues the trajectory from previous post
  const ratioData = [
    1.3, 1.35, 1.4, 1.2, 1.1, 1.15, 1.5, 1.6,
    1.45, 1.5, 1.3, 1.1, 1.2, 1.55, 1.7, 1.8,
    1.6, 1.4, 1.15, 1.2, 1.3, 1.65, 1.75, 1.5,
    1.35, 1.2, 1.5, 1.7, 1.6, 1.45, 1.55, 1.5,
  ];

  // File-level churn (old metric) - backward-looking, file re-edits within 7 days
  const churnData = [
    14, 15, 13, 10, 8, 7, 11, 16,     // first burst: churn rises with throughput
    14, 12, 9, 7, 8, 12, 15, 17,      // second burst: similar pattern
    13, 10, 7, 6, 8, 11, 13, 10,      // learning: churn lower in bursts
    9, 7, 10, 12, 11, 9, 8, 7,        // sustained: churn stabilizing
  ];

  // Reported rework % from trailers - starts sparse, fills in
  // Generally tracks churn but diverges where intent differs from file-level signal
  const reportedRework: (number | null)[] = [
    null, null, 8, null, null, 5, null, 12,       // week 1-2: sparse coverage
    10, 11, null, 5, 6, 9, 13, 14,                // week 3-4: coverage improving
    11, 8, 5, 4, 6, 8, 10, 7,                     // week 5-6: tracks churn loosely
    6, 5, 7, 9, 8, 6, 5, 4,                       // week 7-8: rework trending down
  ];

  const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const gridColor = isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(0, 0, 0, 0.08)';
  const tickColor = isDark ? '#9ca3af' : '#6b7280';

  const ctx = document.getElementById('churn-vs-reported-chart') as HTMLCanvasElement;

  new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Machine:Wall Ratio',
          data: ratioData,
          borderColor: '#06b6d4',
          backgroundColor: 'rgba(6, 182, 212, 0.1)',
          fill: false,
          tension: 0.3,
          pointRadius: 0,
          pointHoverRadius: 3,
          borderWidth: 2,
          spanGaps: true,
          yAxisID: 'y',
        },
        {
          label: 'File Rework (churn)',
          data: churnData,
          borderColor: '#f43f5e',
          backgroundColor: 'rgba(244, 63, 94, 0.1)',
          fill: false,
          tension: 0.3,
          pointRadius: 0,
          pointHoverRadius: 3,
          borderWidth: 2,
          spanGaps: true,
          yAxisID: 'y1',
        },
        {
          label: 'Reported Rework (trailer)',
          data: reportedRework,
          borderColor: '#a78bfa',
          backgroundColor: 'rgba(167, 139, 250, 0.1)',
          fill: false,
          tension: 0.3,
          pointRadius: 2,
          pointHoverRadius: 4,
          borderWidth: 2,
          borderDash: [4, 2],
          spanGaps: false,
          yAxisID: 'y1',
        },
        {
          label: 'Baseline (1.0)',
          data: Array(labels.length).fill(1.0),
          borderColor: isDark ? 'rgba(255, 255, 255, 0.2)' : 'rgba(0, 0, 0, 0.15)',
          borderDash: [6, 4],
          borderWidth: 1,
          pointRadius: 0,
          pointHoverRadius: 0,
          fill: false,
          yAxisID: 'y',
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      aspectRatio: 2.5,
      interaction: {
        intersect: false,
        mode: 'index',
      },
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            color: tickColor,
            usePointStyle: true,
            pointStyle: 'circle',
            padding: 20,
            font: { size: 12 },
            filter: (item) => item.text !== 'Baseline (1.0)',
          },
        },
        tooltip: {
          filter: (item) => item.dataset.label !== 'Baseline (1.0)',
          callbacks: {
            label: (context) => {
              if (context.dataset.yAxisID === 'y1') {
                return `${context.dataset.label}: ${context.parsed.y}%`;
              }
              return `${context.dataset.label}: ${context.parsed.y}x`;
            },
          },
        },
      },
      scales: {
        x: {
          grid: { color: gridColor },
          ticks: {
            color: tickColor,
            maxRotation: 0,
            autoSkip: false,
            font: { size: 11 },
          },
        },
        y: {
          position: 'left',
          grid: { color: gridColor },
          ticks: {
            color: '#06b6d4',
            callback: (value) => `${value}x`,
            font: { size: 11 },
          },
          min: 0.8,
          suggestedMax: 2.0,
        },
        y1: {
          position: 'right',
          grid: { drawOnChartArea: false },
          ticks: {
            color: '#f43f5e',
            callback: (value) => `${value}%`,
            font: { size: 11 },
          },
          min: 0,
          suggestedMax: 25,
        },
      },
    },
  });
</script>

<style>
  .chart-container {
    background-color: #1f2937;
    border-radius: 0.5rem;
    padding: 1.25rem 1.25rem 0.75rem;
    margin: 1.5rem 0;
  }

  .chart-header {
    padding: 0 0.25rem 0.75rem;
  }

  .chart-title {
    color: #f3f4f6;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .chart-subtitle {
    color: #9ca3af;
    font-size: 0.8125rem;
    line-height: 1.4;
  }
</style>
