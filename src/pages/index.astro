---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('posts'))
	.filter(post => import.meta.env.DEV || !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>Hi, I'm Mark.</h1>
				<p>
					I write about building software with AI, the shifting economics of tech work, and
					how people think and talk past each other about politics and culture.
				</p>
				<p>
					Most of what you'll find here is written with AI - I shape the ideas and direction, and
					the AI helps me get them down faster than I ever could alone. Without it, most of these
					posts would still be half-formed notes in my head. When something is written entirely by
					hand, I'll mark it.
				</p>
			</section>

			{posts.length > 0 && (
				<section class="posts">
					<h2>Recent Posts</h2>
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/posts/${post.id}/`}>
									<span class="title">
										{post.data.title}
										{post.data.handwritten
											? <span class="badge handwritten">handwritten</span>
											: <span class="badge ai-assisted">AI-assisted</span>
										}
									</span>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							</li>
						))}
					</ul>
					<a href="/posts" class="view-all">View all posts &rarr;</a>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin-bottom: 3rem;
	}

	.intro h1 {
		margin-bottom: 1rem;
	}

	.intro p {
		color: var(--color-gray-600);
		font-size: 1.1875rem;
		line-height: 1.6;
		margin: 0 0 1rem 0;
	}

	.intro p:last-child {
		margin-bottom: 0;
	}

	.posts h2 {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		margin-bottom: 1rem;
		color: var(--color-gray-500);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.posts ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.posts li {
		border-bottom: 1px solid var(--color-gray-200);
	}

	.posts li:last-child {
		border-bottom: none;
	}

	.posts a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding: 1rem 0;
		text-decoration: none;
		transition: background-color 0.15s ease;
	}

	.posts a:hover {
		text-decoration: none;
	}

	.posts a:hover .title {
		color: var(--color-accent);
	}

	.title {
		color: var(--color-gray-900);
		font-weight: 500;
	}

	.badge {
		display: inline-block;
		padding: 0.125rem 0.5rem;
		border-radius: 0.25rem;
		border: 1px solid currentColor;
		background: transparent;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		margin-left: 0.5rem;
		vertical-align: middle;
	}

	.handwritten {
		color: #1d4ed8;
	}

	.ai-assisted {
		color: var(--color-gray-500);
	}

	.date {
		color: var(--color-gray-500);
		font-size: 0.8125rem;
		font-family: var(--font-mono);
		flex-shrink: 0;
	}

	.view-all {
		display: inline-block;
		margin-top: 1rem;
		font-weight: 500;
	}

	@media (max-width: 640px) {
		.intro p {
			font-size: 1.125rem;
		}

		.posts a {
			flex-direction: column;
			gap: 0.25rem;
		}
	}

	@media (prefers-color-scheme: dark) {
		.intro p {
			color: var(--color-gray-400);
		}

		.posts li {
			border-bottom-color: var(--color-gray-700);
		}

		.title {
			color: var(--color-gray-100);
		}

		.posts a:hover .title {
			color: #60a5fa;
		}

		.handwritten {
			color: #93c5fd;
		}

		.ai-assisted {
			color: var(--color-gray-400);
		}
	}
</style>
