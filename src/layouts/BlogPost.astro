---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'posts'>['data'];

const { title, description, pubDate, updatedDate, tags, handwritten, comments, heroImage, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={ogImage?.src ?? heroImage?.src} />
	</head>
	<body>
		<Header />
		<main class="page-grid">
			<header class="page-title">
				<h1>{title}</h1>
			</header>
			<aside class="page-meta">
				<div class="meta-date">
					<FormattedDate date={pubDate} />
					{updatedDate && (
						<div class="updated">
							Updated <FormattedDate date={updatedDate} />
						</div>
					)}
				</div>
				{handwritten
					? <span class="badge handwritten">handwritten</span>
					: <span class="badge ai-assisted">AI-assisted</span>
				}
				{tags && tags.length > 0 && (
					<ul class="tags">
						{tags.map((tag) => (
							<li><a href={`/tag/${tag}/`} class="tag">#{tag}</a></li>
						))}
					</ul>
				)}
			</aside>
			<div class="page-body">
				<article>
					{heroImage && (
						<img src={heroImage.src} alt="" class="hero-image" width={heroImage.width} height={heroImage.height} />
					)}
					<div class="prose">
						<slot />
					</div>
				</article>
				{comments && (
					<section class="comments">
						<Giscus />
					</section>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title h1 {
		margin-bottom: 0;
	}

	.page-title {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-gray-200);
	}

	.page-meta {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-gray-500);
		margin-bottom: 2rem;
	}

	.meta-date {
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-gray-500);
	}

	.meta-date :global(time) {
		color: var(--color-gray-700);
	}

	.updated {
		font-style: italic;
		margin-top: 0.25rem;
	}

	.tags {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-gray-600);
		text-decoration: none;
		padding: 0.125rem 0.5rem;
		border: 1px solid var(--color-gray-300);
		border-radius: 0.25rem;
		transition: color 0.15s ease, border-color 0.15s ease;
	}

	.tag:hover,
	.tag:focus-visible {
		color: var(--color-accent);
		border-color: var(--color-accent);
		text-decoration: none;
	}

	.badge {
		display: inline-block;
		align-self: flex-start;
		padding: 0.125rem 0.5rem;
		border-radius: 0.25rem;
		border: 1px solid currentColor;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		background: transparent;
	}

	.handwritten {
		color: #1d4ed8;
	}

	.ai-assisted {
		color: var(--color-gray-500);
	}

	.hero-image {
		width: 100%;
		height: auto;
		border-radius: 0.5rem;
		margin-bottom: 2rem;
	}

	/* Widescreen: meta rail layout tweaks */
	@media (min-width: 1024px) {
		.page-title {
			margin-bottom: 2.5rem;
			padding-bottom: 1.5rem;
			/* the spine border on .page-title already provides the left rule */
		}

		.page-meta {
			align-items: flex-start;
			gap: 1.25rem;
			margin-bottom: 0;
		}

		.tags {
			flex-direction: column;
			gap: 0.375rem;
		}

		.tag {
			border: none;
			padding: 0;
			color: var(--color-gray-500);
		}

		.tag:hover,
		.tag:focus-visible {
			color: var(--color-accent);
			border: none;
		}
	}

	.comments {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-gray-200);
	}

	@media (prefers-color-scheme: dark) {
		.page-title {
			border-bottom-color: var(--color-gray-700);
		}

		.comments {
			border-top-color: var(--color-gray-700);
		}

		.meta-date :global(time) {
			color: var(--color-gray-300);
		}

		.handwritten {
			color: #93c5fd;
		}

		.ai-assisted {
			color: var(--color-gray-400);
		}

		.tag {
			color: var(--color-gray-400);
			border-color: var(--color-gray-700);
		}

		.tag:hover,
		.tag:focus-visible {
			color: #60a5fa;
			border-color: #60a5fa;
		}

		@media (min-width: 1024px) {
			.tag {
				color: var(--color-gray-400);
				border: none;
			}

			.tag:hover,
			.tag:focus-visible {
				color: #60a5fa;
				border: none;
			}
		}
	}
</style>
